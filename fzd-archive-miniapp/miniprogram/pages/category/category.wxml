<view class="container">
  <view class="article-list">
    <view class="article-item" wx:for="{{articles}}" wx:key="id" bindtap="onArticleTap" data-id="{{item.id}}">
      <view class="article-info">
        <view class="article-title">{{item.title}}</view>
        <view class="article-desc" wx:if="{{item.description}}">{{item.description}}</view>
      </view>
      <view class="article-meta">
        <text class="lang-tag {{item.lang}}">{{item.lang === 'zh' ? '中' : 'EN'}}</text>
      </view>
    </view>
  </view>
  <view wx:if="{{articles.length === 0}}" class="empty-state">
    <text>暂无内容</text>
  </view>
</view>
