.container {
  padding: 20px;
  background-color: #fff;
  min-height: 100vh;
}

.article-header {
  margin-bottom: 20px;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  display: block;
  margin-bottom: 12px;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 12px;
}

.tag {
  font-size: 12px;
  color: #1AAD19;
  background: #e6f7e8;
  padding: 2px 8px;
  border-radius: 4px;
}

.description {
  font-size: 14px;
  color: #666;
  background: #f8f8f8;
  padding: 12px;
  border-radius: 8px;
  line-height: 1.5;
}

.divider {
  height: 1px;
  background: #eee;
  margin: 20px 0;
}

.article-content {
  font-size: 16px;
  color: #333;
  line-height: 1.8;
}

.article-content text {
  width: 100%;
  display: block;
}

.error {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
}
