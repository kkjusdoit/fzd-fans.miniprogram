.container {
  padding: 20px;
  background-color: #fff;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30px;
}

.logo {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  margin-bottom: 10px;
}

.title {
  font-size: 20px;
  font-weight: bold;
}

.section {
  margin-bottom: 24px;
}

.h2 {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
  display: block;
}

.p {
  font-size: 15px;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-bottom: 10px;
  text-align: justify;
}
