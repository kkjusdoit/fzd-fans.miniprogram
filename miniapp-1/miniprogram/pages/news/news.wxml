<view class="container">
  <view class="news-header">
    <text class="title">📰 樊振东快讯</text>
    <text class="desc">商务 · 宣传 · 赛事 · 出席，记录最新动向</text>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="filter-scroll" scroll-x="true" enable-flex>
    <view class="chip {{activeCat === 'all' ? 'active' : ''}}" data-cat="all" bindtap="onFilterTap">全部</view>
    <view
      class="chip {{activeCat === item.key ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="key"
      data-cat="{{item.key}}"
      bindtap="onFilterTap"
      style="{{activeCat === item.key ? 'background:' + item.color + ';border-color:' + item.color : ''}}"
    >{{item.icon}} {{item.label}}</view>
  </scroll-view>

  <!-- 时间轴（按年分组 + 图标圆点） -->
  <view class="timeline" wx:if="{{groups.length > 0}}">
    <view class="timeline-line"></view>
    <view class="year-group" wx:for="{{groups}}" wx:for-item="group" wx:key="year">
      <view class="year-label"><text>{{group.year}}</text></view>
      <view class="tl-item" wx:for="{{group.list}}" wx:key="index">
        <view class="tl-dot" style="background:{{item.categoryColor}}">{{item.categoryIcon}}</view>
        <view class="tl-card">
          <view class="tl-meta">
            <text class="tl-date">{{item.date}}</text>
            <text class="tl-tag" style="background:{{item.categoryColor}}">{{item.categoryLabel}}</text>
          </view>
          <text class="tl-title">{{item.title}}</text>
          <text class="tl-summary" wx:if="{{item.summary}}">{{item.summary}}</text>
          <image
            wx:if="{{item.image}}"
            class="tl-img"
            src="{{item.image}}"
            mode="widthFix"
            lazy-load="true"
            data-src="{{item.image}}"
            bindtap="onPreviewImage"
          ></image>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text>暂无快讯</text>
  </view>
</view>
