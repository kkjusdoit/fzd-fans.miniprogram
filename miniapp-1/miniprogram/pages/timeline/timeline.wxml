<view class="container">
  <view class="timeline-header">
    <text class="title">赛场时刻</text>
    <text class="desc">记录樊振东职业生涯中的决定性瞬间及最新动向</text>
  </view>

  <view class="honor-banner" bindtap="onPreviewClimbPath">
    <image class="banner-bg" src="https://fzd-fans.com/img/timeline/climb-path.jpg" mode="aspectFill"></image>
    <view class="banner-mask">
      <view class="banner-content">
        <text class="banner-emoji">🏆</text>
        <view class="banner-text-group">
          <text class="banner-title">樊振东 · 登峰之路</text>
          <text class="banner-subtitle">进入国家队获 117 冠、20 个世界冠军荣誉长图</text>
        </view>
        <text class="banner-arrow">➔</text>
      </view>
    </view>
  </view>

  <view class="timeline-list">
    <view class="timeline-line"></view>
    
    <view class="timeline-item {{item.expanded ? 'expanded' : ''}}" 
          wx:for="{{timelineData}}" 
          wx:key="index" 
          bindtap="toggleItem" 
          data-index="{{index}}">
      
      <!-- Dot -->
      <view class="timeline-dot dot-{{item.type}}"></view>

      <!-- Content Card -->
      <view class="timeline-card">
        <view class="card-header">
          <text class="year">{{item.year}}</text>
          <text class="tag {{item.type}}">{{item.typeLabel}}</text>
        </view>
        <text class="card-title">{{item.title}}</text>
        <text class="card-desc">{{item.desc}}</text>
        <view class="expand-indicator" wx:if="{{!item.expanded}}">点击查看详情</view>
        
        <view class="card-detail" wx:if="{{item.expanded}}">
          <text class="detail-text">{{item.detail}}</text>
        </view>
      </view>

    </view>
  </view>
</view>
