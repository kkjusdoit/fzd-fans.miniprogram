.container {
  padding: 12px;
  background-color: #f8fafc;
  min-height: 100vh;
  box-sizing: border-box;
  display: block;
  width: 100%;
}

.warning-banner {
  background-color: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: 10px;
  padding: 10px 14px;
  display: flex;
  align-items: flex-start;
  margin-bottom: 16px;
}

.banner-icon {
  font-size: 14px;
  margin-right: 8px;
}

.banner-text {
  font-size: 11px;
  color: #15803d;
  line-height: 1.4;
}

.gallery-grid {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.gallery-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.photo-card {
  background-color: #ffffff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
  border: 1px solid rgba(241, 245, 249, 0.8);
  transition: transform 0.2s ease;
}

.photo-card:active {
  transform: scale(0.98);
}

.photo-img {
  width: 100%;
  height: auto;
  display: block;
}

.photo-info {
  padding: 8px 10px;
}

.photo-name {
  font-size: 12px;
  font-weight: 500;
  color: #334155;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0;
  width: 100%;
}

.spinner {
  width: 24px;
  height: 24px;
  border: 2px solid #e2e8f0;
  border-top-color: #1e88e5;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 8px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text, .no-more-text, .empty-text {
  font-size: 11px;
  color: #94a3b8;
}

.no-more {
  text-align: center;
  padding: 24px 0;
  width: 100%;
}

.empty-state {
  text-align: center;
  padding: 80px 0;
  width: 100%;
}
