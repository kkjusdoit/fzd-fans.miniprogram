.container {
  padding: 16px;
  background-color: #f8fafc;
  min-height: 100vh;
  box-sizing: border-box;
  display: block;
  width: 100%;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.article-item {
  background: #ffffff;
  padding: 18px;
  border-radius: 12px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.01);
  border: 1px solid rgba(241, 245, 249, 0.8);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  transition: all 0.2s ease;
}

.article-item:active {
  transform: scale(0.99);
  background-color: #f1f5f9;
}

.article-info {
  flex: 1;
}

.article-title {
  font-size: 16px;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 6px;
  line-height: 1.4;
}

.article-desc {
  font-size: 12px;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-state {
  text-align: center;
  padding: 80px 20px;
  color: #94a3b8;
  font-size: 13px;
}
