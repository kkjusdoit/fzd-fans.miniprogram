<view class="container">
  <block wx:if="{{categoryId === 'ugc'}}">
    <view class="ugc-guide-card">
      <view class="guide-top">
        <text class="guide-title">✍️ 欢迎投稿贡献</text>
        <text class="guide-desc">如果你有独到的技战术分析或真挚的来信，欢迎投稿加入我们！收到邮件后会在24小时内处理回复。</text>
      </view>
      <view class="guide-btn" bindtap="copySubmissionEmail">
        <text class="guide-btn-text">点击复制投稿邮箱：kkjusdoit@gmail.com</text>
      </view>
    </view>

    <view class="section-title">💌 繁星寄语</view>
    <view class="article-list">
      <view class="article-item" wx:for="{{letters}}" wx:key="id" bindtap="onArticleTap" data-id="{{item.id}}">
        <view class="article-info">
          <view class="article-title">{{item.title}}</view>
          <view class="article-desc" wx:if="{{item.description}}">{{item.description}}</view>
          <view class="article-author" wx:if="{{item.author}}">作者：{{item.author}}</view>
        </view>
      </view>
    </view>

    <view class="section-title" style="margin-top: 24px;">⚔️ 东风论剑</view>
    <view class="article-list">
      <view class="article-item" wx:for="{{tactics}}" wx:key="id" bindtap="onArticleTap" data-id="{{item.id}}">
        <view class="article-info">
          <view class="article-title">{{item.title}}</view>
          <view class="article-desc" wx:if="{{item.description}}">{{item.description}}</view>
          <view class="article-author" wx:if="{{item.author}}">作者：{{item.author}}</view>
        </view>
      </view>
    </view>
  </block>
  <block wx:else>
    <view class="article-list">
      <view class="article-item" wx:for="{{articles}}" wx:key="id" bindtap="onArticleTap" data-id="{{item.id}}">
        <view class="article-info">
          <view class="article-title">{{item.title}}</view>
          <view class="article-desc" wx:if="{{item.description}}">{{item.description}}</view>
          <view class="article-author" wx:if="{{item.author}}">作者：{{item.author}}</view>
        </view>
      </view>
    </view>
  </block>
  
  <view wx:if="{{articles.length === 0 && letters.length === 0 && tactics.length === 0}}" class="empty-state">
    <text>暂无内容</text>
  </view>
</view>
